# ==========================================
# ENVIRONMENT CONFIGURATION
# ==========================================
ENVIRONMENT=development # development | testing | production

# ==========================================
# POSTGRES DATABASE
# ==========================================
POSTGRES_USER=fintech_user
POSTGRES_PASSWORD=dev_password_change_in_prod
POSTGRES_DB=fintech_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database configuration aliases
DB_HOST=postgres
DB_PORT=5432
DB_USER=fintech_user
DB_PASSWORD=dev_password_change_in_prod
DB_NAME=fintech_db

# ==========================================
# REDIS CACHE & IDEMPOTENCY
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# KAFKA EVENT STREAMING
# ==========================================
KAFKA_BROKERS=kafka:29092
KAFKA_TOPIC=transactions.raw
KAFKA_TOPIC_TRANSACTIONS=transactions.raw
KAFKA_TOPIC_DLQ=transactions.dlq
KAFKA_CONSUMER_GROUP=transaction-processor-group

# ==========================================
# GO INGESTION GATEWAY
# ==========================================
SERVER_PORT=50051
HTTP_PORT=8080
GO_SERVER_PORT=50051
GO_SERVER_HOST=0.0.0.0

# ==========================================
# PYTHON ML ENGINE & MODEL REGISTRY
# ==========================================
PORT=8000
ML_SERVICE_PORT=8000
MODEL_PATH=models/saved_models_v2/xgboost_v2.pkl
MODEL_REGISTRY_PATH=models/registry.json

# ==========================================
# OLLAMA LLM ENGINE
# ==========================================
OLLAMA_HOST=http://ollama:11434

# ==========================================
# FRONTEND DASHBOARD
# ==========================================
VITE_API_BASE_URL=http://localhost:8080

# ==========================================
# OBSERVABILITY & MONITORING
# ==========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=admin

# ==========================================
# SECURITY & AUTHENTICATION
